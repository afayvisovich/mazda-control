<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Доступ к интернету (для socket подключения к автомобилю) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Проверка состояния сети для обработки разрывов подключения -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Запись логов во внешнее хранилище (для удобного извлечения) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Доступ к состоянию загрузки для автозапуска Shizuku -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- Запуск сервисов в фоне для Shizuku -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Shizuku permissions -->
    <uses-permission android:name="rikka.shizuku.permission.BIND_SERVICE" />

    <application
        android:name=".MazdaControlApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MazdaControl"
        android:usesCleartextTraffic="true">
        
        <!-- FileProvider для шеринга логов без root -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MazdaControl">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Shizuku Activation Activity -->
        <activity
            android:name=".ShizukuActivationActivity"
            android:exported="false"
            android:label="Shizuku Activation"
            android:theme="@style/Theme.MazdaControl" />

        <!-- Shizuku Service Starter для автозапуска -->
        <service
            android:name=".ShizukuServiceStarter"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="shortService" />

        <!-- Boot Receiver для автозапуска Shizuku (опционально) -->
        <receiver
            android:name=".ShizukuAutoStarter$BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!-- Mock Mega Service для эмуляции mega.controller -->
        <service
            android:name=".MockMegaService"
            android:enabled="true"
            android:exported="true"
            android:process=":mock_mega_service">
            <intent-filter>
                <action android:name="com.mazda.control.MOCK_MEGA_SERVICE" />
            </intent-filter>
        </service>

    </application>

</manifest>